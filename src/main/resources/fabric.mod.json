{
	"schemaVersion": 1,
	"id": "structscript",
	"version": "${version}",
	"name": "StructScript",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/structscript/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.elthisboy.structscript.StructScript"
		],
		"client": [
			"com.elthisboy.structscript.StructScriptClient"
		]
	},
	"mixins": [
		"structscript.mixins.json",
		{
			"config": "structscript.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}